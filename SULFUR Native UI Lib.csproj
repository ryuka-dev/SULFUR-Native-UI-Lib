  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <!--
    Deploy the built plugin into the Gale profile's plugins folder after a
    successful build. Disable with -p:DeployToProfile=false.
  -->
  <Target Name="DeployToProfile" AfterTargets="Build" Condition=" '$(DeployToProfile)' != 'false' ">
    <MakeDir Directories="$(DeployDir)" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(DeployDir)" SkipUnchangedFiles="false" />
    <Copy SourceFiles="$(TargetDir)$(TargetName).pdb" DestinationFolder="$(DeployDir)" SkipUnchangedFiles="false" Condition="Exists('$(TargetDir)$(TargetName).pdb')" />
    <Message Importance="high" Text="Deployed $(TargetFileName) -> $(DeployDir)" />
    <!-- Also drop the dll into the Thunderstore packaging folder (gitignored). -->
    <MakeDir Directories="$(ThunderstoreDir)" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(ThunderstoreDir)" SkipUnchangedFiles="false" />
    <Message Importance="high" Text="Deployed $(TargetFileName) -> $(ThunderstoreDir)" />
  </Target>
</Project>