    <Compile Include="Options\SulfurOptionsApi.cs" />
    <Compile Include="Options\SulfurOptionsPage.cs" />
    <Compile Include="Options\SulfurOptionsContext.cs" />
    <Compile Include="Integration\SulfurOptionsScreenBridge.cs" />
    <Compile Include="Integration\SulfurOptionsScreenPatch.cs" />
    <Compile Include="Integration\SulfurCustomCategoryMarker.cs" />
    <Compile Include="Rows\SulfurSettingRow.cs" />
