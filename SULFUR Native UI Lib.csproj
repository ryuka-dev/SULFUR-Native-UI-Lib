<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{72A22641-593C-485E-A6BC-6191F7C17244}</ProjectGuid>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>SULFUR_Native_UI_Lib</RootNamespace>
    <AssemblyName>SULFUR Native UI Lib</AssemblyName>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
  </PropertyGroup>
  <!--
    Reference and deploy locations. Override any of these from the command line
    if your install differs, e.g.:
      dotnet build -p:SulfurManagedDir=E:\Steam\...\Managed
      dotnet build -p:DeployProfile=Default
  -->
  <PropertyGroup>
    <!-- SULFUR's managed assemblies (Assembly-CSharp, UnityEngine, etc.). -->
    <SulfurManagedDir Condition=" '$(SulfurManagedDir)' == '' ">D:\SteamLibrary\steamapps\common\SULFUR\Sulfur_Data\Managed</SulfurManagedDir>
    <!-- Gale mod-manager profiles root for SULFUR. -->
    <GaleProfilesDir Condition=" '$(GaleProfilesDir)' == '' ">$(APPDATA)\com.kesomannen.gale\sulfur\profiles</GaleProfilesDir>
    <!-- BepInEx core assemblies (Harmony, BepInEx). Any profile works for compiling. -->
    <BepInExCoreDir Condition=" '$(BepInExCoreDir)' == '' ">$(GaleProfilesDir)\Default\BepInEx\core</BepInExCoreDir>
    <!-- Profile the built plugin is deployed into after a successful build. -->
    <DeployProfile Condition=" '$(DeployProfile)' == '' ">复现bug</DeployProfile>
    <DeployDir Condition=" '$(DeployDir)' == '' ">$(GaleProfilesDir)\$(DeployProfile)\BepInEx\plugins\ryuka_labs-SULFUR_Native_UI_Lib</DeployDir>
    <!-- Thunderstore packaging folder; the built dll is copied here for upload. -->
    <ThunderstoreDir Condition=" '$(ThunderstoreDir)' == '' ">$(MSBuildProjectDirectory)\Thunderstore</ThunderstoreDir>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="0Harmony">
      <HintPath>$(BepInExCoreDir)\0Harmony.dll</HintPath>
    </Reference>
    <Reference Include="Assembly-CSharp">
      <HintPath>$(SulfurManagedDir)\Assembly-CSharp.dll</HintPath>
    </Reference>
    <Reference Include="BepInEx">
      <HintPath>$(BepInExCoreDir)\BepInEx.dll</HintPath>
    </Reference>
    <Reference Include="PerfectRandom.Sulfur.Core">
      <HintPath>$(SulfurManagedDir)\PerfectRandom.Sulfur.Core.dll</HintPath>
    </Reference>
    <Reference Include="System" />
